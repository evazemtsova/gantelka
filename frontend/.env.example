# Supabase (см. Project Settings → API в Supabase Dashboard)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Dev-режим — обходит подключение к Supabase, фронт работает на локальном seed.
# Используется во время разработки фронта без сети / без Supabase.
# Допустимые значения: 'mock' | '' (пусто)
VITE_DEV_AUTH=
