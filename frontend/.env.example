# Firebase (см. Project Settings → Your apps → Web app в Firebase Console)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id

# Dev-режим — обходит подключение к Firebase, фронт работает на локальном seed.
# Используется во время разработки фронта без сети / без Firebase.
# Допустимые значения: 'mock' | '' (пусто)
VITE_DEV_AUTH=
